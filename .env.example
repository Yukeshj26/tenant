# ─── Application ────────────────────────────────────────────────────────────
APP_NAME=TenantSenseAI
APP_ENV=development
APP_SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
DEBUG=true

# ─── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_USER=tenantsense
POSTGRES_PASSWORD=tenantsense_secure_pass
POSTGRES_DB=tenantsense_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://tenantsense:tenantsense_secure_pass@localhost:5432/tenantsense_db

# ─── MongoDB ─────────────────────────────────────────────────────────────────
MONGO_USER=tenantsense
MONGO_PASSWORD=tenantsense_mongo_pass
MONGO_DB=tenantsense_logs
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_URL=mongodb://tenantsense:tenantsense_mongo_pass@localhost:27017/tenantsense_logs

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1

# ─── JWT Authentication ──────────────────────────────────────────────────────
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Google Gemini API ───────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-1.5-flash

# ─── Google Translate (fallback for multilingual) ────────────────────────────
GOOGLE_TRANSLATE_API_KEY=your-google-translate-api-key-here

# ─── ML Model Paths ──────────────────────────────────────────────────────────
ML_MODEL_PATH=machine_learning/models/xgboost_model.pkl
ML_SCALER_PATH=machine_learning/models/scaler.pkl
ML_THRESHOLD=0.5

# ─── CORS ────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ─── Email Alerts ────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-email-app-password
ALERT_FROM_EMAIL=noreply@tenantsense.ai

# ─── Frontend (Next.js) ──────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
NEXT_PUBLIC_APP_NAME=TenantSense AI
